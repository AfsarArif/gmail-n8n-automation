# ─── N8N Connection ───
N8N_BASE_URL=https://your-n8n-domain.com
WF0_SECRET_TOKEN=replace-with-random-secret-token

# ─── DeepSeek API ───
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sk-replace-with-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEMPERATURE=0
DEEPSEEK_MAX_TOKENS=50

# ─── Gmail Accounts (comma-separated) ───
GMAIL_ACCOUNTS=personal@gmail.com,work@gmail.com,side@gmail.com
GMAIL_CREDENTIAL_NAMES=Gmail - personal@gmail.com,Gmail - work@gmail.com,Gmail - side@gmail.com

# ─── Outlook/Hotmail Accounts (comma-separated) ───
OUTLOOK_ACCOUNTS=myname@hotmail.com
OUTLOOK_CREDENTIAL_NAMES=Outlook - myname@hotmail.com

# ─── Classification ───
PRE_CLASSIFIER_ENABLED=true
DEFAULT_FALLBACK_CATEGORY=fyi
SKIP_AI_IF_LABELED=true

# ─── Spam Deletion Schedule ───
SPAM_DELETE_SCHEDULE_CRON="59 23 * * *"
SPAM_DELETE_BATCH_SIZE=50
SPAM_OLDER_THAN_DAYS=1

# ─── Rate Limits ───
GMAIL_POLL_INTERVAL_MINUTES=1
OUTLOOK_POLL_INTERVAL_MINUTES=1
GMAIL_RATE_LIMIT_QPS=250
OUTLOOK_RATE_LIMIT_PER_10MIN=10000

# ─── Retry ───
MAX_RETRIES=3
RETRY_DELAY_MS=2000
