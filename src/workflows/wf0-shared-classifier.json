        },
        "options": {}
      },
      "id": "a0000000-0000-4000-8000-000000000004",
      "name": "Set: Fast Category",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [780, 100]
    },
    {
      "parameters": {
        "jsCode": "// HTML to Plain Text — strip HTML tags for the AI classifier\n// DeepSeek only needs the textual content, not markup.\nconst html = $input.first().json.body_html || $input.first().json.body_text || $input.first().json.snippet || '';\n\n// Simple HTML tag stripping (production-grade would use a real parser,\n// but this is sufficient for the classifier's ~300 char preview)\nconst cleaned = html\n  .replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '')\n  .replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<')\n  .replace(/&gt;/g, '>')\n  .replace(/&quot;/g, '\"')\n  .replace(/&#39;/g, \"'\")\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    cleaned_body: cleaned\n  }\n}];"
      },
      "id": "a0000000-0000-4000-8000-000000000005",
      "name": "HTML to Plain Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [780, 500]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $vars.system_prompt || '\nYou are an email classifier. Return valid JSON only — no markdown, no explanation, no extra text.\n\nClassify the email into exactly one category:\n\n- \"newsletter\":   Blog digests, editorial content, curated reading lists, publication emails\n- \"action\":       Requires a direct reply or response (questions, requests, meeting invites, tasks)\n- \"social\":       Notifications from social platforms (LinkedIn, Twitter/X, Facebook, Instagram, Reddit, GitHub, Discord)\n- \"promotions\":   Sales, discount codes, limited-time offers, marketing campaigns, product launches\n- \"career\":       Job postings, recruiter outreach, interview requests, application updates, job alerts\n- \"fyi\":          Receipts, order confirmations, shipping updates, account notifications, no reply needed\n- \"spam\":         Junk mail, phishing, irrelevant unsolicited bulk mail\n\nReturn exactly this JSON:\n{\n  \"category\": \"newsletter|action|social|promotions|career|fyi|spam\"\n}\n' }}\n\nFrom: {{ $json.from }}\nSubject: {{ $json.subject }}\nBody preview: {{ ($json.cleaned_body || $json.body_text || $json.snippet || '').slice(0, 300) }}"
      },
      "id": "a0000000-0000-4000-8000-000000000006",
      "name": "DeepSeek: Basic LLM Chain",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1,
      "position": [1300, 500]
    },
    {
      "parameters": {
        "model": "deepseek-chat",
        "options": {
          "temperature": 0,
          "maxTokens": 128,
          "topP": 1
        }
      },
      "id": "a0000000-0000-4000-8000-000000000007",
      "name": "DeepSeek Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [1040, 500]
    },
    {
      "parameters": {
        "jsCode": "// Validate + normalize DeepSeek category output\n// The LLM Chain returns raw text — we extract the JSON and validate.\n\nconst validCategories = ['newsletter', 'action', 'social', 'promotions', 'career', 'fyi', 'spam'];\n\nlet rawText = '';\n\n// Try to extract the LLM response from various N8N AI node output shapes\nif ($input.first().json.text) {\n  rawText = $input.first().json.text;\n} else if ($input.first().json.output) {\n  rawText = $input.first().json.output;\n} else if ($input.first().json.response) {\n  rawText = $input.first().json.response;\n} else {\n  // Fallback: stringify entire JSON and try regex extraction\n  rawText = JSON.stringify($input.first().json);\n}\n\n// Attempt JSON parse\nlet category = '';\ntry {\n  // Handle markdown code fences sometimes added by models\n  const clean = rawText\n    .replace(/```json\\s*/gi, '')\n    .replace(/```\\s*/g, '')\n    .trim();\n  const parsed = JSON.parse(clean);\n  category = (parsed.category || '').toString().trim().toLowerCase();\n} catch {\n  // Regex fallback for malformed output\n  const match = rawText.match(/\"category\"\\s*:\\s*\"([^\"]+)\"/i);\n  if (match && match[1]) {\n    category = match[1].trim().toLowerCase();\n  }\n}\n\n// Validate and fall back to 'fyi' if invalid\nconst finalCategory = validCategories.includes(category) ? category : 'fyi';\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    category: finalCategory\n  }\n}];"
      },
